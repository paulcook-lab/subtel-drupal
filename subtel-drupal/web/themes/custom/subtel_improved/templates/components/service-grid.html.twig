{#
/**
 * Service Grid Component - Responsive grid of main services
 */
#}
<section class="service-grid-section" aria-label="Main services">
  <div class="container">
    <h2>{{ 'Servicios Principales'|t }}</h2>
    <p class="section-subtitle">{{ 'Accede a los servicios más demandados de SUBTEL'|t }}</p>

    <div class="service-grid">
      {# Servicio 1: Portal de Solicitudes #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M9 2a1 1 0 000 2h.01a1 1 0 000-2H9zm-1.414 4a2 2 0 112.828 0l-1.414-1.414z"/>
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2h12a1 1 0 100-2 2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V5z"/>
          </svg>
        </div>
        <h3>{{ 'Portal de Solicitudes'|t }}</h3>
        <p>{{ 'Presenta y da seguimiento a tus solicitudes de forma online, segura y transparente'|t }}</p>
        <a href="/solicitudes" class="btn btn-ghost">{{ 'Ir al Portal'|t }} →</a>
      </div>

      {# Servicio 2: Regulaciones Técnicas #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
          </svg>
        </div>
        <h3>{{ 'Regulaciones Técnicas'|t }}</h3>
        <p>{{ 'Descarga y consulta las normativas técnicas y regulatorias vigentes en telecomunicaciones'|t }}</p>
        <a href="/regulaciones" class="btn btn-ghost">{{ 'Ver Regulaciones'|t }} →</a>
      </div>

      {# Servicio 3: Mapa de Cobertura #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5z"/>
          </svg>
        </div>
        <h3>{{ 'Mapa de Cobertura'|t }}</h3>
        <p>{{ 'Consulta la disponibilidad de servicios de telefonía, internet y televisión por región'|t }}</p>
        <a href="/cobertura" class="btn btn-ghost">{{ 'Explorar Mapa'|t }} →</a>
      </div>

      {# Servicio 4: Reclamos y Quejas #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
          </svg>
        </div>
        <h3>{{ 'Presentar Reclamo'|t }}</h3>
        <p>{{ 'Si tienes un problema con tu servicio, presenta un reclamo ante SUBTEL'|t }}</p>
        <a href="/reclamos" class="btn btn-ghost">{{ 'Nuevo Reclamo'|t }} →</a>
      </div>

      {# Servicio 5: Datos Abiertos #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
          </svg>
        </div>
        <h3>{{ 'Datos Abiertos'|t }}</h3>
        <p>{{ 'Acceso a bases de datos públicas, estadísticas y análisis del mercado telecom'|t }}</p>
        <a href="/datos-abiertos" class="btn btn-ghost">{{ 'Ver Dashboard'|t }} →</a>
      </div>

      {# Servicio 6: Contacto y Atención #}
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" width="48" height="48">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
          </svg>
        </div>
        <h3>{{ 'Contacto y Atención'|t }}</h3>
        <p>{{ 'Encuentra nuestras oficinas, horarios de atención y canales de comunicación'|t }}</p>
        <a href="/contacto" class="btn btn-ghost">{{ 'Contactar'|t }} →</a>
      </div>
    </div>
  </div>
</section>
