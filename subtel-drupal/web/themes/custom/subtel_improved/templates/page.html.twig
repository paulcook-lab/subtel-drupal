{#
/**
 * @file
 * Theme override to display a single page.
 * SUBTEL Mejorado - Drupal 10
 */
#}
<div class="page">
  {# Header #}
  <header class="header" role="banner">
    <div class="header-content">
      <div class="logo">
        <a href="{{ url('<front>') }}">SUBTEL</a>
      </div>
      <nav class="main-menu" role="navigation">
        {{ page.navigation }}
      </nav>
    </div>
  </header>

  {# Main Content Area #}
  <main class="main-content" role="main">
    {{ page.content }}
  </main>

  {# Footer #}
  <footer class="footer" role="contentinfo">
    <p>&copy; SUBTEL 2026 - Superintendencia de Telecomunicaciones</p>
  </footer>
</div>
